# -----------------------------------------------------------------------------
# Variables de entorno (plantilla). Copiar a `.env` y ajustar.
#
# Nota: Expo no lee `.env` automáticamente. Si quieres consumirlas desde el
# JS debes:
#   1) Instalar `dotenv` en el script de build, o
#   2) Migrar `app.json` a `app.config.ts` y leer process.env allí.
#
# Mientras tanto, los valores reales viven en `app.json -> expo.extra`.
# -----------------------------------------------------------------------------

# URL base del backend. En simulador iOS usa localhost. En emulador Android
# usa 10.0.2.2. En dispositivo físico usa la IP LAN de tu Mac.
API_URL=http://localhost:3000/api
SOCKET_URL=http://localhost:3000
